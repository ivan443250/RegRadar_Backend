LLM_PROVIDER=mock
POLZA_API_KEY=
POLZA_BASE_URL=https://polza.ai/api/v1
POLZA_MODEL=deepseek/deepseek-v4-flash
POLZA_ALLOWED_MODELS=deepseek/deepseek-v4-flash,openai/gpt-4o,qwen/qwen3.6-plus,qwen/qwen3.5-flash-02-23
POLZA_TIMEOUT_SECONDS=60
POLZA_MAX_RETRIES=2

# Optional integration with the main RegRadar.Api backend.
# Local host: http://localhost:8080
# Shared backend compose network: http://api:8080
# Docker Desktop container -> host: http://host.docker.internal:8080
MAIN_BACKEND_URL=
MAIN_BACKEND_TIMEOUT_SECONDS=30
# Disabled by default: integration must not silently analyze against demo clients.
MAIN_BACKEND_ALLOW_SEED_FALLBACK=false

# Production .NET backend contract deadline.
BACKEND_CONTRACT_TIMEOUT_SECONDS=120

# Optional writable runtime directories (defaults: data/storage and data/logs).
REG_RADAR_STORAGE_DIR=
REG_RADAR_LOG_DIR=
