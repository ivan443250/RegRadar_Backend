FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY Directory.Build.props Directory.Packages.props ./
COPY src/ src/

RUN dotnet restore src/RegRadar.Workers/RegRadar.Workers.csproj
RUN dotnet publish src/RegRadar.Workers/RegRadar.Workers.csproj -c Release -o /app/publish --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .
COPY seed/ seed/
ENTRYPOINT ["dotnet", "RegRadar.Workers.dll"]