# PostgreSQL
POSTGRES_DB=regradar
POSTGRES_USER=regradar
POSTGRES_PASSWORD=change_me

# Bitrix webhook.
# Empty value = mock notification mode.
BITRIX_WEBHOOK_URL=

# Main backend -> AI-service mode.
# http = call regradar_ai container through http://ai:8000
# mock = use built-in .NET mock fallback without external AI-service
AI_MODE=http

# AI-service LLM provider.
# mock = deterministic local baseline, no API key required
# polza = PolzaAI only
# polza_with_fallback = PolzaAI with safe fallback to baseline
LLM_PROVIDER=mock

# PolzaAI settings. Keep the key only in local .env / deployment secrets.
POLZA_API_KEY=
POLZA_MODEL=deepseek/deepseek-v4-flash
