# PostgreSQL
POSTGRES_DB=regradar
POSTGRES_USER=regradar
POSTGRES_PASSWORD=change_me

# Bitrix webhook (empty = mock mode)
BITRIX_WEBHOOK_URL=

# AI module (regradar_ai container)
# AI_MODE: http = backend calls the AI service; mock = backend uses built-in mock fallback
AI_MODE=http
# LLM_PROVIDER (inside AI service): mock (no key needed) | polza
LLM_PROVIDER=mock
POLZA_API_KEY=
POLZA_MODEL=deepseek/deepseek-v4-flash
